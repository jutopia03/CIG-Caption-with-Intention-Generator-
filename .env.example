# AssemblyAI — STT + 화자 분리
# 발급: https://www.assemblyai.com/app/account
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
LLM_MODEL=llama3.1:8b

# pyannote.audio — HuggingFace access token
# 발급: https://huggingface.co/settings/tokens
# 모델 라이선스 동의 필요: https://hf.co/pyannote/speaker-diarization-3.1
PYANNOTE_AUTH_TOKEN=hf_your_token_here
WHISPER_MODEL_SIZE=base
DATA_DIR=data/samples
OUTPUT_DIR=data/outputs

# DeepL — 번역
# 발급: https://www.deepl.com/your-account/keys
DEEPL_API_KEY=your_key_here
# Whisper STT
WHISPER_MODEL_SIZE=large-v3

# NVIDIA NeMo Sortformer diarization
# Hugging Face token may be required by the model loader:
# https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here
SORTFORMER_MODEL_NAME=nvidia/diar_sortformer_4spk-v1
SORTFORMER_MODEL_PATH=
SORTFORMER_BATCH_SIZE=1
SPEAKER_SMOOTH_MAX_SEC=1.2
SPEAKER_SMOOTH_MAX_WORDS=3
SPEAKER_REID_ENABLED=true
SPEAKER_EMBEDDING_MODEL=titanet_large
SPEAKER_EMBEDDING_THRESHOLD=0.72
SPEAKER_EMBEDDING_MIN_SEC=0.7

# Optional streaming Sortformer tuning, measured in 80 ms frames.
# Defaults come from the model unless explicitly set here.
SORTFORMER_CHUNK_LEN=
SORTFORMER_RIGHT_CONTEXT=
SORTFORMER_FIFO_LEN=
SORTFORMER_SPKCACHE_UPDATE_PERIOD=
SORTFORMER_SPKCACHE_LEN=

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
LLM_HOST=http://localhost:11434
LLM_MODEL=llama3.1:8b

DATA_DIR=data/samples
OUTPUT_DIR=data/outputs

# DeepL translation
DEEPL_API_KEY=your_key_here
